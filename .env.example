# Qwen Cloud (Dashscope) — required for hackathon
# Get your key: https://home.qwencloud.com → API Keys
DASHSCOPE_API_KEY=sk-your-api-key-here

# OpenAI-compatible Qwen endpoint (hackathon default)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Default model for scoring, CV rewrite, email drafting
QWEN_MODEL=qwen3.7-plus

# Default model for profile extraction (CV skills, README → project)
PROFILE_LLM_MODEL=qwen-turbo

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Gmail API
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth — register OAuth App: https://github.com/settings/developers
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Alibaba Cloud OSS (CV storage — add when deploying)
# ALIBABA_OSS_ACCESS_KEY_ID=
# ALIBABA_OSS_ACCESS_KEY_SECRET=
# ALIBABA_OSS_BUCKET=
# ALIBABA_OSS_ENDPOINT=

# Google Stitch (UI design MCP — also set in .cursor/mcp.json)
# Create key: https://stitch.withgoogle.com/settings
# STITCH_API_KEY=

# App
# APP_ENV=development
# API_HOST=0.0.0.0
# API_PORT=8000

# Auth & data encryption (generate once; keep secret)
# JWT_SECRET=           # long random string
# JWT_EXPIRE_MINUTES=10080
# DATA_ENCRYPTION_KEY=  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Browser search (local worker — see worker/.env.example and System Design/browser-provider-abstraction.md)
# BROWSER_PROVIDER=browser-use
# BROWSER_EXECUTION=worker
# BROWSER_CHROME_PROFILE=Profile 1

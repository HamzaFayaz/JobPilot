# Qwen Cloud (Dashscope) — required for hackathon
# Get your key: https://home.qwencloud.com → API Keys
DASHSCOPE_API_KEY=sk-your-api-key-here

# OpenAI-compatible Qwen endpoint (hackathon default)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Default model for scoring, CV rewrite, email drafting
QWEN_MODEL=qwen3.7-plus

# Observability — product runs: Logfire on, paid evals off
LOGFIRE_ENABLED=true
LOGFIRE_TOKEN=
LOGFIRE_PROJECT_NAME=jobpilot
LOGFIRE_ENVIRONMENT=development
LOGFIRE_CAPTURE_CONTENT=false
PYDANTIC_EVALS_ENABLED=false
EVAL_CAPTURE_FULL_PAYLOADS=false
EVAL_JUDGE_MODEL=qwen3.7-max-2026-06-08
EVAL_JUDGE_TEMPERATURE=0
EVAL_MAX_CONCURRENCY=1
EVAL_RESULTS_DIR=tests/complete-pipeline-test/results

# Default model for profile extraction (CV skills, README → project)
PROFILE_LLM_MODEL=qwen-turbo

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Gmail API
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth — register OAuth App: https://github.com/settings/developers
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Alibaba Cloud OSS (CV storage — add when deploying)
# ALIBABA_OSS_ACCESS_KEY_ID=
# ALIBABA_OSS_ACCESS_KEY_SECRET=
# ALIBABA_OSS_BUCKET=
# ALIBABA_OSS_ENDPOINT=

# Google Stitch (UI design MCP — also set in .cursor/mcp.json)
# Create key: https://stitch.withgoogle.com/settings
# STITCH_API_KEY=

# App
# APP_ENV=development
# API_HOST=0.0.0.0
# API_PORT=8000

# Auth & data encryption (generate once; keep secret)
# JWT_SECRET=           # long random string
# JWT_EXPIRE_MINUTES=10080
# DATA_ENCRYPTION_KEY=  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Search Helper / browser (system — not user search prefs)
# User max jobs, country, work mode, posted-within live in the JobPilot profile DB.
# BROWSER_PROVIDER=webbridge
# WEBBRIDGE_URL=http://127.0.0.1:10086
# BROWSER_EXECUTION=worker
# cloud = ECS runs Qwen ReAct; worker is WebBridge tool executor (judges need no Dashscope)
# BROWSER_AGENT_MODE=cloud
# BROWSER_SEARCH_WAIT_TIMEOUT_SECONDS=900
# WORKER_HEARTBEAT_STALE_SECONDS=60
# BROWSER_AGENT_MAX_STEPS=40
# BROWSER_AGENT_SAVE_SNAPSHOTS=false
# BROWSER_AGENT_SNAPSHOT_MAX_CHARS=12000

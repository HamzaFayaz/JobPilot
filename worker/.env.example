# JobPilot API — cloud (no port) or local (with port)
# Cloud: http://43.98.197.132
# Local: http://localhost:8000
JOBPILOT_API_BASE=http://localhost:8000
WORKER_TOKEN=

# Agent mode: cloud (default) = server runs Qwen ReAct; Helper is WebBridge-only
AGENT_MODE=cloud

# Do NOT put Dashscope / Qwen model here for normal use — those live on the JobPilot
# server (.env). Local AGENT_MODE=local is a developer fallback only.
# DASHSCOPE_API_KEY=
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# Kimi WebBridge — locked pair: daemon v1.10.0 + extension 1.11.3
# See System Design/kimi-webbridge-provider.md
BROWSER_PROVIDER=webbridge
WEBBRIDGE_URL=http://127.0.0.1:10086

POLL_INTERVAL_SECONDS=3
AGENT_MAX_STEPS=40

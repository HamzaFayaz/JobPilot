JOBPILOT_API_BASE=http://localhost:8000
WORKER_TOKEN=

# Qwen via Dashscope (Option B — your key, used only on this PC)
DASHSCOPE_API_KEY=your-dashscope-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Browser provider — Kimi WebBridge replaces Browser-Use (see System Design/kimi-webbridge-provider.md)
BROWSER_PROVIDER=webbridge
WEBBRIDGE_URL=http://127.0.0.1:10086

# Deprecated (Browser-Use only — remove when browser-use code is deleted):
# BROWSER_CHROME_PROFILE=Default
# BROWSER_USER_DATA_DIR=

# Poll interval in seconds
POLL_INTERVAL_SECONDS=3

# Max Qwen + WebBridge tool steps per search (raise if complex filters time out)
AGENT_MAX_STEPS=40
